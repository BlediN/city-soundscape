{
  "name": "unitygridplaza",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"cd client && vite\" \"cd server && nodemon server.js\"",
    "start": "cd server && node server.js",
    "start:prod": "cd server && NODE_ENV=production node server.js",
    "build": "cd client && vite build",
    "build:gh-pages": "cd client && vite build --mode gh-pages",
    "deploy": "npm run build:gh-pages && gh-pages -d client/dist",
    "db:init": "cd server && node config/reset.js",
    "db:reset": "npm run db:init"
  },
  "dependencies": {
    "@picocss/pico": "^1.5.7",
    "concurrently": "^7.6.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "nodemon": "^2.0.22",
    "pg": "^8.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.9.0",
    "serve-favicon": "^2.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^3.1.0",
    "gh-pages": "^6.3.0",
    "vite": "^4.2.0"
  }
}
